{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':automergeDigest',
    ':automergeMinor',
    ':enablePreCommit',
  ],
  postUpdateOptions: [
    'gomodTidy',
  ],
  'pre-commit': {
    enabled: true,
  },
  packageRules: [
    {
      matchManagers: [
        'github-actions',
      ],
      automerge: true,
    },
    {
      matchUpdateTypes: [
        'digest',
        'pin',
        'patch',
      ],
      automerge: true,
    },
  ],
}
